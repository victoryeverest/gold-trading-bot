# ===========================================
# Gold Trading Bot - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# ===========================================

# ============ NEWS API KEYS ============
# Get free key at: https://newsapi.org/register
# Free tier: 100 requests/day
NEWS_API_KEY=your_newsapi_key_here

# Get free key at: https://finnhub.io/register
# Free tier: 60 calls/minute
FINNHUB_API_KEY=your_finnhub_key_here

# Get free key at: https://www.alphavantage.co/support/#api-key
# Free tier: 25 calls/day
ALPHA_VANTAGE_API_KEY=your_alphavantage_key_here

# ============ TELEGRAM BOT ============
# Create bot with @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ============ EXNESS / MT5 BROKER ============
# Your Exness account details
MT5_LOGIN=your_exness_account_number
MT5_PASSWORD=your_exness_password
MT5_SERVER=Exness-Real

# For Exness demo accounts, use:
# MT5_SERVER=Exness-Demo

# ============ TRADING SETTINGS ============
# Override default settings here (optional)
INITIAL_CAPITAL=50
RISK_PER_TRADE=0.03
MAX_OPEN_TRADES=3
